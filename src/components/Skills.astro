---
import { t, ids, type Lang } from '../i18n/translations';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;

const i = t(lang);
const id = ids(lang);
const groups = i.skills.groups;
const tools = i.skills.tools;
---

<section class="section" id={id.skills}>
  <div class="container">
    <span class="section-eyebrow reveal">{i.skills.eyebrow}</span>
    <h2 class="section-heading reveal reveal-delay-1">{i.skills.heading} <span class="gradient-text">{i.skills.headingAccent}</span></h2>
    <p class="section-desc reveal reveal-delay-2">{i.skills.desc}</p>

    <div class="skills-grid">
      {groups.map((g, idx) => (
        <div class={`skill-card glass reveal reveal-delay-${Math.min((idx % 4) + 1, 3)}`}>
          <div class="skill-icon-wrap">
            <span class="skill-icon" aria-hidden="true">
              {g.icon === 'cloud' && <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>}
              {g.icon === 'blocks' && <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="14" y="3" rx="1"/><path d="M10 21V8a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H3"/></svg>}
              {g.icon === 'monitor' && <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>}
              {g.icon === 'zap' && <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>}
              {g.icon === 'laptop' && <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.28 2.55a1 1 0 0 1-.9 1.45H3.62a1 1 0 0 1-.9-1.45L4 16"/></svg>}
              {g.icon === 'brain' && <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>}
              {g.icon === 'link' && <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>}
              {g.icon === 'shield' && <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>}
            </span>
          </div>
          <h3 class="skill-label">{g.label}</h3>
          <div class="skill-tags">
            {g.techs.map(tech => <span class="tag">{tech}</span>)}
          </div>
        </div>
      ))}
    </div>

    <div class="bottom-row">
      <div class="tools-box glass reveal reveal-delay-1">
        <h4 class="box-heading">
          <span class="heading-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76Z"/></svg></span>
          {i.skills.toolsHeading}
        </h4>
        <div class="tools-cloud">
          {tools.map((tool, idx) => <span class={`tool-chip ${idx % 3 === 0 ? 'tool-highlight' : ''}`}>{tool}</span>)}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .skill-card {
    padding: 1.5rem;
    border-radius: var(--r-lg);
    position: relative;
    overflow: hidden;
  }

  .skill-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gradient);
    opacity: 0;
    transition: opacity 0.4s var(--ease);
  }

  .skill-card:hover::before { opacity: 1; }

  .skill-icon-wrap {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(129, 140, 248, 0.08);
    border: 1px solid rgba(129, 140, 248, 0.12);
    border-radius: var(--r-md);
    margin-bottom: 0.75rem;
    color: var(--accent);
    transition: background 0.3s var(--ease), box-shadow 0.3s var(--ease), transform 0.3s var(--ease);
  }

  .skill-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .skill-card:hover .skill-icon-wrap {
    background: rgba(129, 140, 248, 0.15);
    box-shadow: 0 0 20px rgba(129, 140, 248, 0.15);
    transform: scale(1.05);
  }

  .skill-label {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .skill-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  .bottom-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .box-heading {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-3);
    font-weight: 700;
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .heading-icon {
    display: flex;
    align-items: center;
    color: var(--accent);
  }

  .tools-box { padding: 1.5rem; border-radius: var(--r-lg); }

  .tools-cloud { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  .tool-chip {
    font-size: 0.82rem;
    padding: 0.4rem 0.85rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: var(--r-full);
    color: var(--text-3);
    font-weight: 500;
    transition: all 0.3s var(--ease);
  }

  .tool-chip:hover {
    border-color: var(--border-accent);
    color: var(--accent);
    background: rgba(129, 140, 248, 0.08);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(129, 140, 248, 0.1);
  }

  .tool-highlight { border-color: var(--border-accent); color: var(--accent); }

  @media (max-width: 900px) { .skills-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .skills-grid { grid-template-columns: 1fr; } }
</style>
