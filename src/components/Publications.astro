---
import { t, ids, type Lang } from '../i18n/translations';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;

const i = t(lang);
const id = ids(lang);

// Publications data stays the same (titles are in English already)
const pubs = [
  {
    title: 'Enhancing Software-Defined Perimeters with Integrated Identity Solutions and Threat Detection for Robust Zero Trust Security',
    journal: 'International Journal of Information Security',
    year: 2025,
    doi: 'https://link.springer.com/article/10.1007/s10207-025-01099-9',
    tags: ['SDP', 'DID', 'Identity'],
  },
  {
    title: 'SecureSDP: A Novel SDP Implementation Leveraging Multi-Factor and Biometric Authentication',
    journal: 'International Journal of Information Security',
    year: 2024,
    doi: 'https://link.springer.com/article/10.1007/s10207-024-00863-7',
    tags: ['SDP', 'MFA', 'Biometrics'],
  },
  {
    title: 'Apollon: A Robust Defence System against Adversarial Machine Learning Attacks in IDS',
    journal: 'Journal of Information Security and Applications',
    year: 2023,
    doi: 'https://www.sciencedirect.com/science/article/pii/S016740482300456X?via%3Dihub',
    tags: ['Adversarial ML', 'IDS', 'Defence'],
  },
  {
    title: 'Securing the SDP Framework with Automated Deployments and Advanced Fingerprinting Techniques',
    journal: 'Journal of Network and Computer Applications',
    year: 2023,
    doi: 'https://www.researchgate.net/publication/367325161',
    tags: ['SDP', 'Fingerprinting', 'Security'],
  },
  {
    title: 'Egida: Automated Security Configuration and Testing for Operating System Hardening',
    journal: 'Computer Standards & Interfaces',
    year: 2022,
    doi: 'https://www.sciencedirect.com/science/article/pii/S0167404822000372',
    tags: ['Hardening', 'Automation', 'Security'],
  },
];

// Medium / technical articles
const articles = [
  {
    title: 'How to Develop Safer Applications in Node.js',
    platform: 'Better Programming · Medium',
    url: 'https://betterprogramming.pub/',
  },
  {
    title: 'Blockchain Frameworks',
    platform: 'Coinmonks · Medium',
    url: 'https://medium.com/coinmonks',
  },
  {
    title: 'Creando una API Rest con Hyperledger Fabric',
    platform: 'Coinmonks · Medium',
    url: 'https://medium.com/coinmonks',
  },
];

const articlesSectionTitle = lang === 'es' ? 'Artículos técnicos' : 'Technical Articles';
const articlesSectionDesc = lang === 'es' ? 'Publicaciones de divulgación técnica en Medium.' : 'Technical blog posts published on Medium.';
---

<section class="section" id={id.publications}>
  <div class="container">
    <span class="section-eyebrow reveal">{i.publications.eyebrow}</span>
    <h2 class="section-heading reveal reveal-delay-1">{i.publications.heading} <span class="gradient-text">{i.publications.headingAccent}</span></h2>
    <p class="section-desc reveal reveal-delay-2">{i.publications.desc}</p>

    <div class="pub-stats reveal reveal-delay-2">
      {i.publications.stats.map(s => (
        <div class="pub-stat">
          <span class="stat-icon" aria-hidden="true">
            {s.icon === 'file-text' && <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>}
            {s.icon === 'bar-chart' && <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>}
            {s.icon === 'eye' && <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>}
          </span>
          <div class="stat-content">
            <span class="pub-num">{s.value}</span>
            <span class="pub-label">{s.label}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="pub-list">
      {pubs.map((p, idx) => (
        <a class={`pub-card glass reveal reveal-delay-${Math.min(idx + 1, 4)}`} href={p.doi} target="_blank" rel="noopener noreferrer">
          <span class="pub-index">{String(idx + 1).padStart(2, '0')}</span>
          <div class="pub-body">
            <h3 class="pub-title">{p.title}</h3>
            <p class="pub-journal">{p.journal} · {p.year}</p>
            <div class="pub-tags">
              {p.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>
          <div class="pub-arrow-wrap">
            <svg class="pub-arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
          </div>
        </a>
      ))}
    </div>

    <div class="pub-links reveal reveal-delay-3">
      <a href="https://scholar.google.com/citations?user=4bCBOysAAAAJ" target="_blank" rel="noopener noreferrer" class="pub-ext">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15 15 0 0 1 4 10 15 15 0 0 1-4 10 15 15 0 0 1-4-10 15 15 0 0 1 4-10z"/></svg>
        Google Scholar
      </a>
      <a href="https://orcid.org/0000-0001-8353-7902" target="_blank" rel="noopener noreferrer" class="pub-ext">
        ORCID
      </a>
      <a href="https://www.researchgate.net/profile/Antonio-Paya-3" target="_blank" rel="noopener noreferrer" class="pub-ext">
        ResearchGate
      </a>
    </div>

    <!-- Technical Articles (Medium) -->
    <div class="articles-section reveal reveal-delay-2">
      <h3 class="articles-heading">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.855z"/></svg>
        {articlesSectionTitle}
      </h3>
      <p class="articles-desc">{articlesSectionDesc}</p>
      <div class="articles-list">
        {articles.map(a => (
          <a class="article-card glass" href={a.url} target="_blank" rel="noopener noreferrer">
            <div class="article-body">
              <h4 class="article-title">{a.title}</h4>
              <span class="article-platform">{a.platform}</span>
            </div>
            <div class="pub-arrow-wrap">
              <svg class="pub-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .pub-stats {
    display: flex;
    gap: 2rem;
    margin-bottom: 2.5rem;
    padding: 1.25rem 1.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    backdrop-filter: blur(20px);
  }

  .pub-stat { display: flex; align-items: center; gap: 0.75rem; }

  .stat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--r-md);
    background: rgba(129, 140, 248, 0.08);
    border: 1px solid rgba(129, 140, 248, 0.12);
    color: var(--accent);
    flex-shrink: 0;
  }

  .stat-content { display: flex; flex-direction: column; }

  .pub-num {
    font-size: 1.5rem;
    font-weight: 800;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.2;
  }

  .pub-label { font-size: 0.75rem; color: var(--text-4); font-weight: 500; }

  .pub-list { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 2rem; }

  .pub-card {
    display: flex;
    align-items: start;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    border-radius: var(--r-lg);
    text-decoration: none;
    color: inherit;
  }

  .pub-card:hover { color: inherit; }

  .pub-card:hover .pub-arrow-wrap {
    background: rgba(129, 140, 248, 0.15);
    border-color: var(--border-accent);
  }

  .pub-card:hover .pub-arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }

  .pub-index {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
    background: rgba(129, 140, 248, 0.08);
    padding: 0.3rem 0.6rem;
    border-radius: var(--r-sm);
    flex-shrink: 0;
    margin-top: 0.1rem;
    border: 1px solid rgba(129, 140, 248, 0.12);
  }

  .pub-body { flex: 1; min-width: 0; }

  .pub-title {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.5;
    margin-bottom: 0.3rem;
  }

  .pub-journal {
    font-size: 0.75rem;
    color: var(--accent);
    margin-bottom: 0.6rem;
    font-family: var(--mono);
  }

  .pub-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  .pub-arrow-wrap {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--r-sm);
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.03);
    flex-shrink: 0;
    transition: all 0.3s var(--ease);
  }

  .pub-arrow {
    color: var(--text-4);
    transition: all 0.3s var(--ease);
  }

  .pub-links {
    display: flex;
    gap: 1rem;
  }

  .pub-ext {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-4);
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--r-full);
    transition: all 0.3s var(--ease);
  }

  .pub-ext:hover {
    color: var(--accent);
    border-color: var(--border-accent);
    background: rgba(129, 140, 248, 0.05);
  }

  @media (max-width: 768px) {
    .pub-stats { flex-direction: column; gap: 1rem; }
    .pub-card { flex-direction: column; }
  }

  /* Technical Articles (Medium) */
  .articles-section {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .articles-heading {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.3rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .articles-heading svg { color: var(--accent); }

  .articles-desc {
    font-size: 0.88rem;
    color: var(--text-3);
    margin-bottom: 1.25rem;
  }

  .articles-list { display: flex; flex-direction: column; gap: 0.5rem; }

  .article-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-radius: var(--r-lg);
    text-decoration: none;
    color: inherit;
  }

  .article-card:hover { color: inherit; }

  .article-card:hover .pub-arrow-wrap {
    background: rgba(129, 140, 248, 0.15);
    border-color: var(--border-accent);
  }

  .article-card:hover .pub-arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }

  .article-body { flex: 1; min-width: 0; }

  .article-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.15rem;
  }

  .article-platform {
    font-size: 0.75rem;
    color: var(--accent);
    font-family: var(--mono);
  }
</style>
